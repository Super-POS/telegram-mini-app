{
  "name": "telegram-mini-app",
  "version": "1.0.0",
  "description": "Telegram Bot & Mini App for CoffeeShop POS",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "nodemon",
    "typecheck": "tsc --noEmit",
    "tunnel": "cloudflared tunnel --url http://127.0.0.1:${WEBHOOK_PORT:-3002}"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
