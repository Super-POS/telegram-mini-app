# ──────────────────────────────────────────────
#  Customer Telegram bot (NOT the cashier alert bot)
# ──────────────────────────────────────────────
# Create a dedicated bot in @BotFather for shoppers (Mini App + /start).
# On api-v1 set the SAME token as TELEGRAM_CUSTOMER_BOT_TOKEN (or TELEGRAM_WEBAPP_BOT_TOKEN).
# Use a separate bot + token on api-v1 for cashier order alerts (TELEGRAM_CASHIER_BOT_TOKEN).
BOT_TOKEN=your_customer_bot_token_here

# ──────────────────────────────────────────────
#  POS API (api-v1)
# ──────────────────────────────────────────────
API_BASE_URL=http://localhost:9003

# Admin credentials used for the bot's service account
# (must have admin/seller role in POS)
ADMIN_USERNAME=0889566929
ADMIN_PASSWORD=123456

# ──────────────────────────────────────────────
#  Webhook (optional — leave blank to use polling)
# ──────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_PORT=3001

# ──────────────────────────────────────────────
#  Bot session storage (optional — shared Postgres with api-v1)
# ──────────────────────────────────────────────
# If SESSION_DB_HOST+SESSION_DB_DATABASE (or DB_HOST+DB_DATABASE) are set, sessions live in
# table telegram_bot_sessions. Otherwise uses data/sessions.json on disk.
# SESSION_DB_HOST=127.0.0.1
# SESSION_DB_PORT=9001
# SESSION_DB_DATABASE=pos
# SESSION_DB_USERNAME=postgres
# SESSION_DB_PASSWORD=

# ──────────────────────────────────────────────
#  Telegram Mini App
# ──────────────────────────────────────────────
# Public HTTPS URL for Telegram Mini App (customer_web_v1). Tunnel the bot server (WEBHOOK_PORT, default 3002):
#   cd telegram-mini-app && npm run tunnel
# Or tunnel customer_web_v1 directly if you skip the bot proxy.
# Example: https://abc-xyz.trycloudflare.com (from cloudflared output)
WEBAPP_URL=https://your-subdomain.trycloudflare.com
CUSTOMER_WEB_BASE_URL=https://your-subdomain.trycloudflare.com

# ──────────────────────────────────────────────
#  Admin Telegram chat IDs (comma-separated)
#  These receive monthly reports & can run /broadcast
# ──────────────────────────────────────────────
ADMIN_CHAT_IDS=

# ──────────────────────────────────────────────
#  App
# ──────────────────────────────────────────────
NODE_ENV=development

# GCP VM (optional): run scripts/prepare-gcp-vm-env.sh with GCP_PUBLIC_HOST set; use:
#   docker compose -f docker-compose.yml -f docker-compose.gcp.yml up -d --build
# Vercel static webapp (telegram-mini-app-eight-beta): set rewrite destination in vercel.json
# "rewrites" → API_REWRITE_TARGET (your GCP api-v1 URL, e.g. http://HOST:9003).
# Browser calls same-origin /api/* on Vercel; do not rely on localhost in production.

# Telegram Mini App: HTTPS is standard; http:// needs WEBAPP_ALLOW_HTTP=true for keyboard buttons (see src/config).
# Self-hosted HTTP Mini App on customer web (:9007): set WEBAPP_ALLOW_HTTP=true (see docker-compose.gcp.yml).
WEBAPP_ALLOW_HTTP=
